# Auto-detect text files
* text=auto

# Source code
*.py text eol=lf
*.rs text eol=lf

# Configuration
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerignore text eol=lf

# GitHub
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
